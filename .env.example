# Email address shown in the From header
SENDER_EMAIL=your_email@yourdomain.com

# SMTP server connection (Private Email)
SMTP_SERVER=mail.privateemail.com
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USERNAME=your_email@yourdomain.com
SMTP_PASSWORD=your_mail_password

# Transport security (set only one true)
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Optional timeout (seconds)
SMTP_TIMEOUT=30

# Application form receiver
APPLICATION_RECEIVER_EMAIL=hr@yourdomain.com

# Flask app settings
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
APPLICATION_MAX_UPLOAD_MB=5

# Applicant profile variables used by send_company_applications.py
APPLICANT_NAME=Your Name
APPLICANT_EMAIL=your_email@yourdomain.com
APPLICANT_PHONE=+971000000000
APPLICANT_PORTFOLIO=https://yourportfolio.com
APPLICANT_LINKEDIN=https://www.linkedin.com/in/your-profile

# Legacy fallback supported by code (optional)
# APP_PASSWORD=legacy_password_value
